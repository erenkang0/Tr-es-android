<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sand"
    android:padding="20dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tv_flashcards_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/flashcards_title"
        style="@style/Text.Display"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tv_progress" />

    <TextView
        android:id="@+id/tv_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        style="@style/Text.SectionLabel"
        app:layout_constraintBaseline_toBaselineOf="@id/tv_flashcards_title"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Center card (clickable, flips) -->
    <LinearLayout
        android:id="@+id/card_flip"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_card"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:minHeight="320dp"
        android:orientation="vertical"
        android:padding="28dp"
        app:layout_constraintTop_toBottomOf="@id/tv_flashcards_title"
        app:layout_constraintBottom_toTopOf="@id/buttons_barrier"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5">

        <TextView
            android:id="@+id/tv_card_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            style="@style/Text.Word" />

        <TextView
            android:id="@+id/tv_card_meaning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:visibility="gone"
            style="@style/Text.Meaning" />

        <TextView
            android:id="@+id/tv_card_example"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:visibility="gone"
            style="@style/Text.Example" />

        <TextView
            android:id="@+id/tv_tap_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/flashcards_tap_hint"
            style="@style/Text.Chip" />

    </LinearLayout>

    <!-- Finish state -->
    <TextView
        android:id="@+id/tv_done"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/flashcards_done"
        android:visibility="gone"
        style="@style/Text.Meaning"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_restart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_restart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/flashcards_restart"
        android:visibility="gone"
        app:backgroundTint="@color/terracotta"
        app:layout_constraintTop_toBottomOf="@id/tv_done"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/flashcards_empty"
        android:visibility="gone"
        style="@style/Text.Meaning.Small"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Barrier so the card stops above the buttons row -->
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/buttons_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="btn_dont_know,btn_know" />

    <!-- Bottom answer buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_dont_know"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="6dp"
        android:text="@string/flashcards_dont_know"
        app:layout_constraintWidth_percent="0.5"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_know" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_know"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginStart="6dp"
        android:text="@string/flashcards_know"
        app:backgroundTint="@color/terracotta"
        app:layout_constraintWidth_percent="0.5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_dont_know"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
