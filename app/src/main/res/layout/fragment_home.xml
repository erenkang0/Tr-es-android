<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sand"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <!-- 1) Language toggle row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_lang_toggle"
                style="@style/Text.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lang_toggle" />
        </LinearLayout>

        <!-- 2) Language pair label -->
        <TextView
            style="@style/Text.SectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/lang_pair" />

        <!-- 3) Display title -->
        <TextView
            style="@style/Text.Display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/title_dictionary" />

        <!-- 4) Search bar -->
        <LinearLayout
            android:id="@+id/search_bar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_search_field"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_search"
                app:tint="@color/ink_muted" />

            <TextView
                style="@style/Text.Meaning.Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/hint_search" />
        </LinearLayout>

        <!-- 5) Word of day section label -->
        <TextView
            style="@style/Text.SectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/section_word_of_day" />

        <!-- 6) Word of day card -->
        <LinearLayout
            android:id="@+id/card_wod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_wod_word"
                        style="@style/Text.Word"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="hablar" />

                    <TextView
                        android:id="@+id/tv_wod_pron"
                        style="@style/Text.Pronunciation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        tools:text="/aˈβlaɾ/" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/btn_wod_audio"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_audio"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/cd_play_pronunciation">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_volume"
                        app:tint="@color/terracotta" />
                </FrameLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_wod_pos"
                style="@style/Text.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_chip_pos"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                tools:text="fiil" />

            <TextView
                android:id="@+id/tv_wod_meaning"
                style="@style/Text.Meaning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                tools:text="konuşmak, söylemek" />

            <TextView
                android:id="@+id/tv_wod_example"
                style="@style/Text.Example"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                tools:text="Me gusta hablar contigo." />
        </LinearLayout>

        <!-- 7) Recent searches section label -->
        <TextView
            style="@style/Text.SectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/section_recent" />

        <!-- 8) Recent empty state -->
        <TextView
            android:id="@+id/tv_recent_empty"
            style="@style/Text.Meaning.Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/recent_empty"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- 9) Recent searches list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_recent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_recent_search"
            tools:orientation="horizontal" />

        <!-- 10) Flashcards CTA card -->
        <LinearLayout
            android:id="@+id/card_cta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_cta_dark"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="22dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/Text.CtaTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cta_flashcards_title" />

                <TextView
                    android:id="@+id/tv_cta_sub"
                    style="@style/Text.CtaSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    tools:text="15 kelime · tekrar et" />
            </LinearLayout>

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_arrow_right"
                app:tint="@color/card" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
